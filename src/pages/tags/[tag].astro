---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NoteCard from "../../components/NoteCard.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);
  const tags = [...new Set(notes.flatMap((note) => note.data.tags))].sort();

  return tags.map((tag) => ({
    params: { tag: tag.toLowerCase().replaceAll(" ", "-") },
    props: {
      tag,
      notes: notes.filter((note) => note.data.tags.includes(tag)),
    },
  }));
}

const { tag, notes } = Astro.props;
const sortedNotes = notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={`${tag} notes | Marceli Grabowski`} description={`Technical notes tagged ${tag}.`}>
  <nav class="mb-10">
    <a
      href="/"
      class="group inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider hover:text-accent transition-colors duration-300"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 7 7 17M7 7v10h10" />
      </svg>
      <span class="border-b border-current group-hover:border-accent">Back to notes</span>
    </a>
  </nav>

  <header class="mb-14 border-b-2 border-current pb-8">
    <div class="mb-4 text-xs font-mono uppercase tracking-[0.22em] text-accent">Editorial tag</div>
    <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none">
      {tag}
    </h1>
  </header>

  <div class="flex flex-col gap-6">
    {sortedNotes.map((note) => (
      <NoteCard
        slug={note.slug}
        title={note.data.title}
        description={note.data.description}
        date={note.data.date}
        tags={note.data.tags}
      />
    ))}
  </div>
</Layout>
