---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import NoteCard from "../components/NoteCard.astro";
import TagList from "../components/TagList.astro";

const notes = (await getCollection("notes", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tags = [
  "Legacy",
  "Cloud",
  "Kotlin",
  "Architecture",
  "Identity",
  "Observability",
  "Decision-making",
  "Modernization",
];
---

<Layout>
  <section class="mb-20 md:mb-28">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10">
      <div class="col-span-1 lg:col-span-9">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter leading-none text-pretty">
          Technical notes from working with complex backend, cloud and legacy systems.
        </h1>
        <p class="mt-8 max-w-4xl text-xl md:text-2xl leading-relaxed opacity-80 text-pretty">
          Notes on system takeover, pragmatic architecture, Kotlin/Java backend, cloud platforms and technical decision-making.
        </p>
      </div>

      <div class="col-span-1 lg:col-span-3 lg:pl-10">
        <div class="border-l-4 border-accent pl-5">
          <div class="text-xs font-mono uppercase tracking-wider opacity-60">Purpose</div>
          <p class="mt-3 text-lg leading-relaxed opacity-85">
            Not a portfolio grid. Not a content machine. Just practical notes about how I reason through difficult systems.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-16 border-y border-current py-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-6">
      <div class="col-span-1 lg:col-span-3">
        <h2 class="text-sm font-mono uppercase tracking-widest border-b border-current inline-block pb-1">
          Themes
        </h2>
      </div>
      <div class="col-span-1 lg:col-span-9">
        <TagList tags={tags} linked={false} />
      </div>
    </div>
  </section>

  <section>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10">
      <div class="col-span-1 lg:col-span-3">
        <h2 class="text-sm font-mono uppercase tracking-widest border-b border-current inline-block pb-1">
          Published notes
        </h2>
      </div>
      <div class="col-span-1 lg:col-span-9 flex flex-col gap-6">
        {notes.map((note) => (
          <NoteCard
            slug={note.slug}
            title={note.data.title}
            description={note.data.description}
            date={note.data.date}
            tags={note.data.tags}
          />
        ))}
      </div>
    </div>
  </section>
</Layout>
