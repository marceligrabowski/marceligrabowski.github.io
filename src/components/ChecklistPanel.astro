---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="checklist-panel">
  <div class="checklist-panel__label">Checklist</div>
  <h2>{title}</h2>
  <div class="checklist-panel__body">
    <slot />
  </div>
</section>

<style>
  .checklist-panel {
    margin: 2.5rem 0;
    border: 2px solid currentColor;
    padding: 1.4rem;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .checklist-panel__label {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .checklist-panel h2 {
    margin: 0.45rem 0 1rem;
    border: 0;
    padding: 0;
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 900;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .checklist-panel__body :global(p) {
    margin: 0 0 1rem;
  }

  .checklist-panel__body :global(ul) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .checklist-panel__body :global(li) {
    position: relative;
    padding-left: 1.4rem;
    line-height: 1.55;
  }

  .checklist-panel__body :global(li::before) {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 900;
  }

  @media (max-width: 760px) {
    .checklist-panel__body :global(ul) {
      grid-template-columns: 1fr;
    }
  }
</style>
