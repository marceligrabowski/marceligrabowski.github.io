---
const links = [
  { href: "https://www.marceligrabowski.pl/", label: "Homepage" },
  { href: "https://www.linkedin.com/in/marceligrabowski/", label: "LinkedIn" },
  { href: "https://github.com/marceligrabowski", label: "GitHub" },
];
---

<header class="mb-16 border-b-2 border-current pb-6">
  <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
    <a href="/" class="group block" aria-label="Technical notes home">
      <div class="text-xs font-mono uppercase tracking-[0.22em] opacity-60 group-hover:text-accent group-hover:opacity-100 transition-all duration-300">
        Marceli Grabowski
      </div>
      <div class="mt-2 text-3xl md:text-5xl font-black uppercase tracking-tighter leading-none group-hover:text-accent transition-colors duration-300">
        Technical notes
      </div>
    </a>

    <nav class="flex flex-wrap gap-3" aria-label="Primary navigation">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith("http") ? "_blank" : undefined}
          rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class="inline-flex items-center gap-2 border-2 border-current px-4 py-2 text-xs font-bold uppercase tracking-wider hover:bg-[var(--text-color)] hover:text-[var(--bg-color)] transition-all duration-300"
        >
          {link.label}
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M8 7h9v9" />
          </svg>
        </a>
      ))}
    </nav>
  </div>
</header>
