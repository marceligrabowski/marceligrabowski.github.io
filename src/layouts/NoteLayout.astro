---
import Layout from "./Layout.astro";
import TagList from "../components/TagList.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} | Marceli Grabowski`} description={description} type="article">
  <nav class="mb-10">
    <a
      href="/"
      class="group inline-flex items-center gap-2 text-sm font-mono uppercase tracking-wider hover:text-accent transition-colors duration-300"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 7 7 17M7 7v10h10" />
      </svg>
      <span class="border-b border-current group-hover:border-accent">Back to notes</span>
    </a>
  </nav>

  <article class="grid grid-cols-1 lg:grid-cols-12 gap-y-12">
    <header class="col-span-1 lg:col-span-12 border-b-2 border-current pb-8 mb-4">
      <div class="mb-4 text-xs font-mono uppercase tracking-[0.22em] text-accent">
        Technical note
      </div>
      <h1 class="max-w-6xl text-4xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter leading-none text-pretty">
        {title}
      </h1>
      <p class="mt-6 max-w-4xl text-xl md:text-2xl leading-relaxed opacity-80 text-pretty">
        {description}
      </p>
      <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <time datetime={date.toISOString()} class="text-sm font-mono uppercase tracking-wider opacity-60">
          {formattedDate}
        </time>
        <TagList tags={tags} />
      </div>
    </header>

    <aside class="col-span-1 lg:col-span-3 lg:pr-10">
      <div class="sticky top-10 border-l-4 border-accent pl-4 text-sm leading-relaxed opacity-80">
        <div class="font-mono uppercase tracking-wider text-xs mb-2 opacity-70">Working principle</div>
        Documentation is useful, but it is a hypothesis until the system confirms it.
      </div>
    </aside>

    <div class="col-span-1 lg:col-span-7">
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </div>
  </article>
</Layout>
